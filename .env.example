SECRET_KEY=
DEBUG=True
APP_URL=http://localhost:8001

# Banco (Django)
# Se `python manage.py migrate` no PC der erro "Can't connect to MySQL server on 'db'":
# o hostname `db` só existe DENTRO do Docker. Opções:
#   1) Migrar no contentor: na raiz do repo → `docker compose exec web python manage.py migrate`
#   2) No host: cria `.env.local` (ver `.env.local.example`) com DB_HOST=127.0.0.1 e DB_PORT=3307,
#      com o MySQL a correr (`docker compose up -d db`).
#
# Portas: no docker-compose o MySQL expõe 3307 no teu PC (host) → 3306 no contentor.
# - Django a CORRER DENTRO do Compose (serviço web): DB_HOST=db e DB_PORT=3306 (rede interna).
# - Django a CORRER NA MÁQUINA (fora do Docker), MySQL só no Docker: DB_HOST=127.0.0.1 e DB_PORT=3307.
DB_ENGINE=django.db.backends.mysql
DB_NAME=controle_db
DB_USER=root
DB_PASSWORD=
DB_HOST=db
DB_PORT=3306

# MySQL (docker-compose serviço `db`). Em produção use valores fortes e distintos do local.
MYSQL_DATABASE=controle_db
MYSQL_USER=user
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# --- DBeaver / outro cliente no PC (porta 3307 = só este projeto; 3306 fica livre para outros) ---
# Servidor: 127.0.0.1 ou localhost · Porta: 3307 · Base: igual a MYSQL_DATABASE / DB_NAME
# Utilizador: prefere MYSQL_USER + MYSQL_PASSWORD (criados como 'user'@'%' — aceitam ligações
# vindas do host; o MySQL vê o IP como 172.x.x.1, não como 127.0.0.1).
# Se usares root: a senha tem de ser exatamente MYSQL_ROOT_PASSWORD. No DBeaver (driver MySQL 8+),
# em "Driver properties" ou na URL JDBC: allowPublicKeyRetrieval=true (e useSSL=false em dev).

# JWT (access em minutos; refresh em dias)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=25
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# CORS: lista separada por vírgula. Com DEBUG=True, o Django faz união desta lista com as
# origens de desenvolvimento pré-definidas (localhost/127.0.0.1, portas Vite comuns).
# Regex localhost (qualquer porta): omita CORS_ALLOW_LOCALHOST_REGEX para herdar DEBUG.
# Em produção (DEBUG=False), só entram as origens que listar aqui (ou deixe vazio para usar só o default).
CORS_ALLOWED_ORIGINS=http://localhost:2486,http://127.0.0.1:2486,http://localhost:2487,http://127.0.0.1:2487,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175
# CORS_ALLOW_LOCALHOST_REGEX=
