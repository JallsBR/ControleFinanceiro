# Copia para `.env.local` na raiz do repositório (fica fora do git).
# O Django carrega primeiro `.env` e depois isto com override — útil quando o `.env`
# tem DB_HOST=db (Docker) mas queres correr `manage.py` no WSL/host contra o MySQL
# exposto em localhost:3307.
#
#   cp .env.local.example .env.local
#
# Garante que o contentor MySQL está a correr: `docker compose up -d db`

DB_HOST=127.0.0.1
DB_PORT=3307
